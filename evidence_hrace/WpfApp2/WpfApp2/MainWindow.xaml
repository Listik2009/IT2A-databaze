<Window x:Class="EvidenceHracu.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Evidence hráčů" Height="450" Width="800">

    <Grid Margin="10">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <DataGrid x:Name="dgHraci"
                  Grid.Column="0"
                  Margin="0,0,10,0"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Jméno" Binding="{Binding Jmeno}" Width="*" />
                <DataGridTextColumn Header="Tým" Binding="{Binding Tym}" Width="*" />
                <DataGridTextColumn Header="Věk" Binding="{Binding Vek}" Width="60"/>
                <DataGridTextColumn Header="Góly" Binding="{Binding PocetGolu}" Width="60"/>
                <DataGridCheckBoxColumn Header="Aktivní" Binding="{Binding JeAktivni}" Width="80"/>
            </DataGrid.Columns>

        </DataGrid>

        <StackPanel Grid.Column="1">

            <TextBlock FontSize="18" FontWeight="Bold" Margin="0,0,0,10">
                Evidence hráčů
            </TextBlock>

            <TextBlock>Jméno</TextBlock>
            <TextBox x:Name="txtJmeno"/>

            <TextBlock>Tým</TextBlock>
            <TextBox x:Name="txtTym"/>

            <TextBlock>Věk</TextBlock>
            <TextBox x:Name="txtVek"/>

            <TextBlock>Počet gólů</TextBlock>
            <TextBox x:Name="txtGoly"/>

            <CheckBox x:Name="chkAktivni" Margin="0,10,0,10">
                Hráč je aktivní
            </CheckBox>

            <Button Content="Přidat" Click="BtnAdd_Click"/>
            <Button Content="Načíst" Click="BtnLoad_Click"/>
            <Button Content="Upravit" Click="BtnEdit_Click"/>
            <Button Content="Smazat" Click="BtnDelete_Click"/>

        </StackPanel>

    </Grid>
</Window>