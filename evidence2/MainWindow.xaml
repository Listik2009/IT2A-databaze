<Window x:Class="EvidenceHracu.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Evidence hráčů" Height="450" Width="800">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <!-- TABULKA -->
        <DataGrid x:Name="dgHraci"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Jméno" Binding="{Binding Jmeno}" Width="*"/>
                <DataGridTextColumn Header="Tým" Binding="{Binding Tym}" Width="*"/>
                <DataGridTextColumn Header="Věk" Binding="{Binding Vek}" Width="60"/>
                <DataGridTextColumn Header="Pozice" Binding="{Binding Pozice}" Width="100"/>
                <DataGridTextColumn Header="Góly" Binding="{Binding PocetGolu}" Width="60"/>
                <DataGridCheckBoxColumn Header="Aktivní" Binding="{Binding JeAktivni}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- FORM -->
        <StackPanel Grid.Column="1" Margin="10">

            <TextBlock Text="Jméno"/>
            <TextBox x:Name="txtJmeno"/>

            <TextBlock Text="Tým"/>
            <TextBox x:Name="txtTym"/>

            <TextBlock Text="Věk"/>
            <TextBox x:Name="txtVek"/>

            <TextBlock Text="Pozice"/>
            <TextBox x:Name="txtPozice"/>

            <TextBlock Text="Góly"/>
            <TextBox x:Name="txtGoly"/>

            <CheckBox x:Name="chkAktivni" Content="Aktivní"/>

            <Button Content="Přidat" Click="Pridej_Click" Margin="0,10,0,0"/>
            <Button Content="Smazat" Click="Smaz_Click"/>
        </StackPanel>
    </Grid>
</Window>